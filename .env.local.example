# Supabase保存用。ブラウザには出さず、Next.jsのAPI側だけで使います。
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 販売版ログイン用。フロントエンドに出してよいanon keyだけを設定します。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 管理者だけが全店舗へ入るための長いキー。数字だけでも動きますが、販売時は長い文字列を推奨します。
STORE_MASTER_KEY=change-this-to-a-long-private-admin-key

# 営業デモ店舗をSupabase Authでパスワードなし体験させるために、サーバー側だけで使う内部パスワードです。
# 利用者には見せません。VercelのEnvironment Variablesにも設定してください。
DEMO_USER_PASSWORD=change-this-to-a-long-private-demo-password

# 旧PINログインを移行・管理用途で一時的に使う場合だけ true にします。本番販売時は false 推奨です。
ENABLE_LEGACY_PIN_LOGIN=false

# 原材料OCR用。使わない場合は空でもアプリ本体は動きます。
OPENAI_API_KEY=your-openai-api-key

# AI経営判断用。未設定ならAPI側の初期値を使います。
OPENAI_MANAGEMENT_MODEL=gpt-4o-mini
