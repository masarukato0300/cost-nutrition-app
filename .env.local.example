# Supabase保存用。ブラウザには出さず、Next.jsのAPI側だけで使います。
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 販売版ログイン用。フロントエンドに出してよいanon keyだけを設定します。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 管理者だけが全店舗へ入るための長いキー。数字だけでも動きますが、販売時は長い文字列を推奨します。
STORE_MASTER_KEY=change-this-to-a-long-private-admin-key

# 原材料OCR用。使わない場合は空でもアプリ本体は動きます。
OPENAI_API_KEY=your-openai-api-key

# AI経営判断用。未設定ならAPI側の初期値を使います。
OPENAI_MANAGEMENT_MODEL=gpt-4o-mini

# 商圏分析用。Google Geocoding API / Places API を有効にしたキーを設定します。
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
