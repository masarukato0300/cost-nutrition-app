# Supabase保存用。ブラウザには出さず、Next.jsのAPI側だけで使います。
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 今の実装ではフロントエンドからSupabaseへ直接接続しないため未使用です。
# 将来Supabase Authを入れる場合だけ使います。
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 管理者だけが全店舗へ入るための長いキー。数字だけでも動きますが、販売時は長い文字列を推奨します。
STORE_MASTER_KEY=change-this-to-a-long-private-admin-key

# 原材料OCR用。使わない場合は空でもアプリ本体は動きます。
OPENAI_API_KEY=your-openai-api-key
